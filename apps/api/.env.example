# Server
PORT=3000
BASE_URL=https://your-api-name.onrender.com
NODE_ENV=production

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# AI
GEMINI_API_KEY=replace-with-your-gemini-key

# Database (choose ONE approach)
# Option A: Single connection string (recommended on Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL=true

# Option B: Split DB variables
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=postgres

# Demo-only: enable automatic schema sync without migrations
DB_SYNCHRONIZE=true
