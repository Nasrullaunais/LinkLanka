# Backend runtime
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Local PostgreSQL (docker compose)
POSTGRES_PORT=5433
DB_HOST=postgres
DB_PORT=5432
DB_USER=linklanka_admin
DB_PASSWORD=your_db_password
DB_NAME=linklanka_db
DB_SSL=false
DB_SYNCHRONIZE=true

# Required secrets
JWT_SECRET=your_jwt_secret
GEMINI_API_KEY=your_gemini_api_key

# Optional: use external Postgres (Neon/Render). When set, backend uses this first.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional tuning
TTS_MAX_CONCURRENCY=2
GEMINI_TRANSLATION_MODEL=gemini-3-flash-preview
GEMINI_TRANSLATION_FALLBACK_MODEL=gemini-2.5-flash
TRANSLATION_MODEL_MAX_RETRIES=1
TRANSLATION_TIMEOUT_MS_TEXT=30000
TRANSLATION_TIMEOUT_MS_MEDIA=60000
TTS_MANDATORY_ENGLISH_RETRIES=1
DOMINANT_LANGUAGE_LOW_CONFIDENCE_THRESHOLD=65

# AWS S3 media storage
AWS_S3_BUCKET=amzn-leo-bucket
AWS_S3_REGION=ap-south-1
AWS_S3_PREFIX=linklanka/
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_SESSION_TOKEN=
