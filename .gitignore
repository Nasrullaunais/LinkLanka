## Node / JS
node_modules/
dist/
build/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
/.pnp/
.pnp.js
.pnpm-store

## pnpm / workspace
node_modules/
/packages/**/node_modules/
/apps/**/node_modules/

## Android build artifacts (also covered by apps/mobile/android/.gitignore,
## but listed here so `git archive` and manual zips stay clean too)
apps/mobile/android/build/
apps/mobile/android/app/build/
apps/mobile/android/app/.cxx/
apps/mobile/android/.gradle/
apps/mobile/android/.kotlin/

## API compiled output
apps/api/dist/

## Runtime upload / audio directories (generated at runtime, not source)
apps/api/uploads/
apps/api/audios/

## Environment
.env
.env.local
.env.*.local
.env.secrets
.env.home
apps/mobile/.env.home
apps/api/.env.example

## Editor/OS
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

## Logs
logs
*.log
npm-debug.log*
yarn-debug.log*

## Nest / TypeScript
dist/
*.tsbuildinfo

## Next / Web
.next/
out/

## React Native / Mobile
/android/
/ios/
.expo/
*.keystore

# Google / Firebase service files (keep out of repo)
**/google-services.json
**/GoogleService-Info.plist
**/service-account*.json
**/serviceAccount*.json
**/firebase-adminsdk*.json
**/*credentials*.json

